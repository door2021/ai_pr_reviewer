# ── App ──────────────────────────────────────────────────────────
APP_NAME="DeepReviewAI"
DEBUG=true
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://root:@localhost:3306/ai_pr

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =================================================================
# AI PROVIDERS — both are FREE, no credit card needed
# Add at least one. System auto-falls back to Groq if OpenRouter fails.
# =================================================================

# ── OpenRouter (PRIMARY — free 50 req/day, no card needed) ───────
# 1. Go to: https://openrouter.ai
# 2. Sign up with Google or email
# 3. Go to API Keys → Create API Key → copy it here
OPENROUTER_API_KEY=sk-or-your-key-here

# Which free model to use. Options:
#   meta-llama/llama-3.3-70b-instruct:free  ← recommended (reliable + good quality)
#   deepseek/deepseek-r1:free               ← best reasoning (slower)
#   qwen/qwen3-coder-480b-instruct:free     ← best for code (when available)
#   google/gemini-2.0-flash-exp:free        ← fast Google model (when available)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Groq (FALLBACK — free 14,400 req/day, just email signup) ─────
# 1. Go to: https://console.groq.com
# 2. Sign up with Google or email (NO credit card)
# 3. Go to API Keys → Create API Key → copy it here
GROQ_API_KEY=gsk_your-key-here

# Groq model (both are free on free tier):
#   llama-3.3-70b-versatile  ← best quality
#   llama-3.1-8b-instant     ← fastest if 70b is slow
GROQ_MODEL=llama-3.3-70b-versatile

# =================================================================

# ── GitHub ───────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=change-this-too
# GITHUB_CLIENT_ID=      ← only needed for OAuth app (not PAT flow)
# GITHUB_CLIENT_SECRET=  ← only needed for OAuth app (not PAT flow)

# ── CORS (add your prod domain when deploying) ───────────────────
# CORS_ORIGINS=["https://yourdomain.com","http://localhost:5173"]

# =================================================================
# STRIPE — Free to use in test mode, no credit card needed to start
# =================================================================
# 1. Go to https://stripe.com → Create free account
# 2. Stay in TEST MODE (toggle top-right of dashboard)
# 3. Go to Developers → API Keys → copy both keys below
# 4. Test card: 4242 4242 4242 4242 | any future date | any CVC

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook secret — for local dev use Stripe CLI:
#   brew install stripe/stripe-cli/stripe
#   stripe login
#   stripe listen --forward-to localhost:8000/api/v1/billing/webhook
#   Copy the "whsec_..." key it shows
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs — create products in Stripe Dashboard → Products → Add Product
# For each: set recurring monthly price, copy the "price_..." ID
# Use TEST mode price IDs during development (they look the same but aren't charged)
STRIPE_PRICE_SOLO=price_solo_id_here
STRIPE_PRICE_TEAM=price_team_id_here
STRIPE_PRICE_PRO=price_pro_id_here
